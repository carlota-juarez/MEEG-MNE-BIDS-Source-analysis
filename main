#!/bin/bash
#PBS -l nodes=1:ppn=4
#PBS -l mem=32gb
#PBS -l walltime=12:00:00
set -e

# Make output directory
mkdir -p out_dir
mkdir -p html_report

# Moderate parallelism
# Prevent from creating too many threads to avoid an Out Of Memory (OOM) error in Brainlife
export OMP_NUM_THREADS=4
export OPENBLAS_NUM_THREADS=4
export MKL_NUM_THREADS=4
export NUMEXPR_NUM_THREADS=4
export VECLIB_MAXIMUM_THREADS=4
export SINGULARITYENV_OMP_NUM_THREADS=4
export SINGULARITYENV_OPENBLAS_NUM_THREADS=4
export SINGULARITYENV_MKL_NUM_THREADS=4
export SINGULARITYENV_NUMEXPR_NUM_THREADS=4
export SINGULARITYENV_VECLIB_MAXIMUM_THREADS=4

# Force PyVista/VTK to use a virtual GPU
 
export SINGULARITYENV_PYVISTA_OFF_SCREEN="true"
export SINGULARITYENV_QT_QPA_PLATFORM="offscreen"
export SINGULARITYENV_MPLBACKEND="Agg"
export SINGULARITYENV_VTK_DEFAULT_OPENGL_WINDOW="vtkOSOpenGLRenderWindow"

# Include the FreeSurfer FS_LICENSE for the computing resource used to launch the app
export SINGULARITYENV_FS_LICENSE="$FS_LICENSE"

# Own image (uploaded to GitHub)
singularity exec -e docker://ghcr.io/carlota-juarez/app-mne-bids@sha256:68f14c878fc7cc8797d8e359e4786d323779e844a14acee2181ab24e71daca27 python3 main.py
